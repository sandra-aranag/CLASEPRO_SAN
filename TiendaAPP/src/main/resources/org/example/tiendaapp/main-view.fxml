<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="400.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tiendaapp.controller.MainController">
    <top>
        <Text fill="#ff0b0b" strokeType="OUTSIDE" strokeWidth="0.0" text="Primera app javafx" BorderPane.alignment="CENTER">
            <font>
                <Font name="Comic Sans MS" size="20.0" />
            </font>
            <cursor>
                <Cursor fx:constant="DEFAULT" />
            </cursor>
        </Text>
    </top>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <center>
        <VBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <TextField fx:id="editNombre" alignment="CENTER" promptText="introduce tu nombre">
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                </TextField>
            <FlowPane alignment="CENTER" hgap="20.0">
               <children>
                      <Button fx:id="btnSaludar" mnemonicParsing="false" text="Saludar" />
                  <Button fx:id="btnLimpiar" mnemonicParsing="false" text="Limpiar" />
               </children>
            </FlowPane>
            </children>
        </VBox>
    </center>
    <bottom>
        <Text fx:id="textSaludo" strokeType="OUTSIDE" strokeWidth="0.0" BorderPane.alignment="CENTER" />
    </bottom>
</BorderPane>
